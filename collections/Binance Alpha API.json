{
  "info": {
    "name": "Alpha Trading REST API",
    "description": {
      "content": "APIs for Binance Alpha Trading.",
      "type": "text/markdown"
    },
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "const ts = Date.now();",
          "let queryParamsObject = {};",
          "let bodyParamsObject = {};",
          "const postmanEnvironment = pm.environment.get('environment');",
          "const api_key = pm.environment.get('api-key');",
          "const api_secret = pm.environment.get('api-secret');",
          "const parameters = pm.request.url.query;",
          "const body = pm.request.body;",
          "",
          "// set host based on env",
          "const normalizedEnvironment = String(postmanEnvironment || 'production').toLowerCase();",
          "const environmentUrlKeyMap = {",
          "    production: 'prod_url',",
          "    prod: 'prod_url',",
          "    testnet: 'testnet_url',",
          "    demo: 'demo_url'",
          "};",
          "const selectedUrlKey = environmentUrlKeyMap[normalizedEnvironment] || 'prod_url';",
          "const selectedUrl = pm.variables.get(selectedUrlKey) || pm.variables.get('prod_url');",
          "",
          "// set host based on env",
          "pm.request.url.host = [selectedUrl];",
          "",
          "// Collect query params",
          "parameters.each((param) => {",
          "    if (param.key !== 'signature' && !is_empty(param.value) && !is_disabled(param.disabled)) {",
          "        queryParamsObject[param.key] = param.value;",
          "    }",
          "});",
          "",
          "// add timestamp",
          "Object.assign(queryParamsObject, { timestamp: ts });",
          "",
          "// Collect body params if urlencoded",
          "let hasUrlencodedBodyParams = false;",
          "",
          "if (body) {",
          "    const contentTypeHeader = pm.request.headers.get('Content-Type') || pm.request.headers.get('content-type') || '';",
          "    const isFormUrlencoded = contentTypeHeader.includes('application/x-www-form-urlencoded') || body.mode === 'urlencoded';",
          "",
          "    if (isFormUrlencoded && body.urlencoded) {",
          "        body.urlencoded.each((param) => {",
          "            if (param.key !== 'signature' && !is_empty(param.value) && !is_disabled(param.disabled)) {",
          "                bodyParamsObject[param.key] = param.value;",
          "                hasUrlencodedBodyParams = true;",
          "            }",
          "        });",
          "    }",
          "}",
          "",
          "// set api key",
          "setOrUpdateHeaderParam('X-MBX-APIKEY', api_key);",
          "",
          "// only sign if a signature param was declared and we have a secret",
          "if (parameters.has('signature') && api_secret) {",
          "    // canonical query strings",
          "    const queryStringForSign = buildQueryString(queryParamsObject);",
          "    const bodyStringForSign = buildQueryString(bodyParamsObject);",
          "    const totalParams = queryStringForSign + bodyStringForSign;",
          "",
          "    const encoder = new TextEncoder();",
          "    const keyData = encoder.encode(api_secret);",
          "    const msgData = encoder.encode(totalParams);",
          "",
          "    pm.request.url.query.clear();",
          "",
          "    const cryptoKey = await crypto.subtle.importKey('raw', keyData, { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']);",
          "    const signatureBuffer = await crypto.subtle.sign('HMAC', cryptoKey, msgData);",
          "",
          "    const signature = Array.from(new Uint8Array(signatureBuffer))",
          "        .map((b) => b.toString(16).padStart(2, '0'))",
          "        .join('');",
          "",
          "    // update request",
          "    const finalQueryParams = Object.assign({}, queryParamsObject, { signature });",
          "    const finalQueryString = buildQueryString(finalQueryParams);",
          "    pm.request.url.query = finalQueryString;",
          "}",
          "",
          "function buildQueryString(params) {",
          "    if (!params) return '';",
          "",
          "    const pairs = [];",
          "    Object.entries(params).forEach(([key, value]) => {",
          "        if (value !== null && value !== undefined) {",
          "            const serializedValue = serializeValue(value);",
          "            pairs.push(`${key}=${encodeURIComponent(serializedValue)}`);",
          "        }",
          "    });",
          "",
          "    return pairs.join('&');",
          "}",
          "",
          "function serializeValue(value) {",
          "    if (value === null || value === undefined) return '';",
          "    if (Array.isArray(value) || (typeof value === 'object' && value !== null)) return JSON.stringify(value);",
          "",
          "    return String(value);",
          "}",
          "",
          "function setOrUpdateHeaderParam(key, value) {",
          "    let headers = pm.request.headers;",
          "    let header = headers.find((header) => header.key === key);",
          "    if (header) header.value = value;",
          "    else pm.request.headers.add({ key, value });",
          "}",
          "",
          "function is_disabled(val) {",
          "    return val === true;",
          "}",
          "",
          "function is_empty(str) {",
          "    if (str === null || str === undefined) return true;",
          "    if (typeof str === 'string') {",
          "        return (",
          "            !str ||",
          "            str.length === 0 ||",
          "            !/[^\\\\s]/.test(str) ||",
          "            /^\\\\s*$/.test(str) ||",
          "            str.replace(/\\\\s/g, '') === ''",
          "        );",
          "    }",
          "    return false;",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
